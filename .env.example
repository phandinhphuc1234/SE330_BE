# Copy this file to .env for local development, then fill real values.
# Do not commit real secrets.

# PostgreSQL
POSTGRES_DB=mydatabase
POSTGRES_USER=myuser
POSTGRES_PASSWORD=change-me-local
POSTGRES_PORT=5432

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT
# Use a long random value in real environments.
JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-characters

# HMAC secret for ebook reading-session token hashes.
# In production, keep this separate from JWT_SECRET and rotate via a planned process.
EBOOK_READING_SESSION_SECRET=change-me-to-another-long-random-secret

# Mail / Resend SMTP
# RESEND_API_KEY starts with re_. Do not commit the real value.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxx
# Free Resend testing commonly uses onboarding@resend.dev.
# With a verified domain, use no-reply@your-domain.com instead.
MAIL_FROM=onboarding@resend.dev

# Base URL used inside verification emails.
# Local browser on the same machine: http://localhost:8080
# Phone/other device on same Wi-Fi: http://YOUR_COMPUTER_LAN_IP:8080
# VPS/production: https://api.your-domain.com
APP_VERIFICATION_BASE_URL=http://localhost:8080

# Multipart uploads. Keep this aligned with EbookPdfValidator's 100MB limit.
APP_MULTIPART_MAX_FILE_SIZE=100MB
APP_MULTIPART_MAX_REQUEST_SIZE=110MB

# VNPAY Sandbox Payment Gateway
# Fill real sandbox credentials in .env only. Do not commit real values.
VNPAY_TMN_CODE=your-vnpay-terminal-code
VNPAY_HASH_SECRET=your-vnpay-hash-secret
VNPAY_ENABLED=true
VNPAY_PAYMENT_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_TRANSACTION_URL=https://sandbox.vnpayment.vn/merchant_webapi/api/transaction
VNPAY_RETURN_URL=http://localhost:3000/payment/vnpay-return
VNPAY_IPN_URL=http://localhost:8080/api/payments/ipn/vnpay
VNPAY_VERSION=2.1.0
VNPAY_COMMAND=pay
VNPAY_ORDER_TYPE=other
VNPAY_LOCALE=vn
VNPAY_EXPIRE_MINUTES=15
VNPAY_REQUEST_TIMEOUT_MS=5000

# PgAdmin
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=change-me-pgadmin-password

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me-grafana-password
