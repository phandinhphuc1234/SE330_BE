# Server
PORT=8081
NODE_ENV=development

# Allowed origin of the frontend app (Next.js dev server)
FRONTEND_URL=http://localhost:3000

# JWT secret used to verify access tokens issued by the main Athenaeum API (SE330 backend).
# Must match the secret used by the main auth service so payment can validate the user's token.
JWT_SECRET=change-me-shared-secret

# Main library API base URL (used to look up loan info, etc. - optional / for future integration)
LIBRARY_API_URL=http://localhost:8080

# Mock payment gateway settings
PAYMENT_GATEWAY_SUCCESS_RATE=1
PAYMENT_RETURN_BASE_URL=http://localhost:3000/payment
